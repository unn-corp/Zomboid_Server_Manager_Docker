# =============================================================================
# PZ Server Manager — Laravel Production Environment
# =============================================================================
# Copy to app/.env on the production server, or run: make prod-init
# Values in docker-compose.yml `environment:` block override these.
# =============================================================================

APP_NAME="PZ Server Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ── Security ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=zomboid
DB_USERNAME=zomboid
DB_PASSWORD=

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ── Broadcasting / Filesystem / Queue ───────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ── Cache ───────────────────────────────────────────────────────────────────
CACHE_STORE=redis

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=   # Leave empty for no auth; set a value to enable --requirepass on Redis and AUTH in Laravel

# ── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Vite ────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ── API ─────────────────────────────────────────────────────────────────────
API_KEY=

# ── Game Server (RCON) ──────────────────────────────────────────────────────
PZ_SERVER_NAME=ZomboidServer
PZ_RCON_HOST=game-server
PZ_RCON_PORT=27015
PZ_RCON_PASSWORD=
PZ_RCON_TIMEOUT=5
PZ_DATA_PATH=/pz-data

# ── Docker ──────────────────────────────────────────────────────────────────
GAME_SERVER_CONTAINER_NAME=pz-game-server

ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Game Settings ───────────────────────────────────────────────────────────
PZ_GAME_PORT=16261
PZ_DIRECT_PORT=16262
PZ_MAX_PLAYERS=16
PZ_MAP_NAMES="Muldraugh, KY"
PZ_PUBLIC_SERVER=true
PZ_PAUSE_ON_EMPTY=true
PZ_AUTOSAVE_INTERVAL=15
PZ_STEAM_VAC=true
PZ_SERVER_PASSWORD=
PZ_ADMIN_PASSWORD=
PZ_MOD_IDS=
PZ_WORKSHOP_IDS=
PZ_FORCE_UPDATE=false

TZ=Asia/Tbilisi
