{
  "mcpServers": {
    "laravel-boost": {
      "command": "php",
      "args": [
        "app/artisan",
        "boost:mcp"
      ]
    },
    "shadcn-ui": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/claude-code-mcp-proxy",
        "https://www.shadcn.io/api/mcp"
      ],
      "env": {}
    },
    "playwright": {
      "command": "/home/trongio/.nvm/versions/node/v24.14.0/bin/node",
      "args": [
        "/home/trongio/.nvm/versions/node/v24.14.0/bin/npx",
        "@playwright/mcp@latest"
      ],
      "env": {
        "PATH": "/home/trongio/.nvm/versions/node/v24.14.0/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  }
}
